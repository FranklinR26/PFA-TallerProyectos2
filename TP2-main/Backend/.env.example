# ─── Servidor ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/horarioconti
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/horarioconti
MONGO_URI=mongodb://localhost:27017/horarioconti

# ─── JWT ─────────────────────────────────────────────────────
# Cambia JWT_SECRET por una cadena larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# ─── CORS (solo producción) ───────────────────────────────────
# CLIENT_URL=https://tu-dominio.com
